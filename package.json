    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.3.5",
    "typescript": "5.9.3"
  },
  "overrides": {
    "prismjs": "^1.30.0"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}

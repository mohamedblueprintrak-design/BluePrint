// BluePrint Engineering Consultancy - SaaS Platform
// نظام إدارة مكاتب الاستشارات الهندسية

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

/// User roles in the system
enum UserRole {
  ADMIN            // Full system access
  MANAGER          // Project management access
  PROJECT_MANAGER  // Project-level management
  ENGINEER         // Technical access
  DRAFTSMAN        // Drafting and drawing access
  ACCOUNTANT       // Financial access
  HR               // Human resources access
  SECRETARY        // Office management and documents
  VIEWER           // Read-only access
}

/// Permission types for fine-grained access control
enum Permission {
  // Project permissions
  PROJECT_CREATE
  PROJECT_READ
  PROJECT_UPDATE
  PROJECT_DELETE
  
  // Task permissions
  TASK_CREATE
  TASK_READ
  TASK_UPDATE
  TASK_DELETE
  
  // Client permissions
  CLIENT_CREATE
  CLIENT_READ
  CLIENT_UPDATE
  CLIENT_DELETE
  
  // Invoice permissions
  INVOICE_CREATE
  INVOICE_READ
  INVOICE_UPDATE
  INVOICE_DELETE
  
  // User management permissions
  USER_CREATE
  USER_READ
  USER_UPDATE
  USER_DELETE
  
  // Settings permissions
  SETTINGS_READ
  SETTINGS_UPDATE
  
  // Reports permissions
  REPORTS_READ
  REPORTS_EXPORT
  
  // Budget permissions
  BUDGET_MANAGE
  
  // Document permissions
  DOCUMENT_CREATE
  DOCUMENT_READ
  DOCUMENT_UPDATE
  DOCUMENT_DELETE
}

/// Project status
enum ProjectStatus {
  PENDING
  ACTIVE
  ON_HOLD
  COMPLETED
  DESIGN
  SUBMISSION
  APPROVAL
  CONSTRUCTION
  CANCELLED
}

/// Task priority
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Task status
enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

/// Invoice status
enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

/// Contract status
enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  EXPIRED
  TERMINATED
  COMPLETED
}

/// Contract type
enum ContractType {
  SERVICE
  CONSTRUCTION
  CONSULTING
  MAINTENANCE
}

/// Proposal status
enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

/// Defect severity
enum DefectSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Defect status
enum DefectStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

/// Risk status
enum RiskStatus {
  OPEN
  MITIGATED
  CLOSED
  ACCEPTED
}

/// General priority (shared across models)
enum PriorityLevel {
  LOW
  NORMAL
  MEDIUM
  HIGH
  URGENT
}

/// Subscription status
enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

/// Payment status
enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

/// Leave request status
enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Leave type
enum LeaveType {
  ANNUAL
  SICK
  EMERGENCY
  MATERNITY
  PATERNITY
  UNPAID
}

/// Attendance status
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HOLIDAY
}

/// Site report status
enum SiteReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

/// Transmittal status
enum TransmittalStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  REJECTED
  OVERDUE
}

/// Transmittal item status
enum TransmittalItemStatus {
  FOR_REVIEW
  FOR_APPROVAL
  FOR_INFORMATION
  FOR_ACTION
}

/// Purchase order status
enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RECEIVED
  CANCELLED
}

/// Document status
enum DocumentStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  SUPERSEDED
  ARCHIVED
}

/// Signature status
enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
}

/// Amendment status
enum AmendmentStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Risk action status
enum RiskActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

/// Supplier type
enum SupplierType {
  MATERIALS
  EQUIPMENT
  SERVICES
  SUBCONTRACTOR
}

/// Knowledge article category
enum KnowledgeCategory {
  GUIDE
  FAQ
  POLICY
  TEMPLATE
}

// ============================================
// NEW: Task Types for Government Approvals
// أنواع المهام للاعتمادات الحكومية
// ============================================

/// Task type for categorization
enum TaskType {
  STANDARD      // مهمة عادية
  GOVERNMENTAL  // جهة حكومية
  MANDATORY     // إلزامية للترخيص
  CLIENT        // موافقة العميل
  INTERNAL      // مهمة داخلية
}

/// SLA breach status for monitoring
enum SLABreachStatus {
  WARNING       // تحذير قبل انتهاء SLA
  BREACHED      // تجاوز SLA
  CRITICAL      // تجاوز حرج
  RESOLVED      // تم الحل
}

/// Government approval status
enum GovernmentApprovalStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

/// Utility connection status (electrical, plumbing, HVAC)
enum UtilityConnectionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

/// Material transaction type
enum MaterialTransactionType {
  IN
  OUT
  ADJUSTMENT
}

/// Two-factor challenge type
enum TwoFactorChallengeType {
  TOTP
  BACKUP
  SMS
}

/// Transmittal delivery method
enum TransmittalDeliveryMethod {
  EMAIL
  HAND
  COURIER
  POST
}

/// Transmittal response type
enum TransmittalResponseType {
  ACKNOWLEDGED
  APPROVED
  APPROVED_WITH_COMMENTS
  REJECTED
  REVISE_RESUBMIT
}

/// Notification type
enum NotificationType {
  SYSTEM
  TASK
  PROJECT
  INVOICE
  APPROVAL
  MENTION
  DEADLINE
  SLA_WARNING
  SLA_BREACH
}

/// Document type
enum DocumentType {
  GENERAL
  CONTRACT
  DRAWING
  REPORT
  INVOICE
  TRANSMITTAL
  SPECIFICATION
  CALCULATION
  PHOTO
}

/// Document category
enum DocumentCategory {
  TECHNICAL
  FINANCIAL
  LEGAL
  ADMINISTRATIVE
}

/// Risk category
enum RiskCategory {
  TECHNICAL
  FINANCIAL
  SCHEDULE
  EXTERNAL
  ORGANIZATIONAL
  SAFETY
  ENVIRONMENTAL
}

/// Risk response strategy
enum RiskResponseStrategy {
  AVOID
  MITIGATE
  TRANSFER
  ACCEPT
}

/// BOQ item category
enum BOQCategory {
  CIVIL
  STRUCTURAL
  MEP
  FINISHING
  EXTERNAL
  INFRASTRUCTURE
}

/// Subscription interval
enum SubscriptionInterval {
  MONTH
  YEAR
}

// ============================================
// المنظمة والاشتراكات (SaaS Core)
// ============================================

model Organization {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  logo             String?
  description      String?
  website          String?
  phone            String?
  email            String?
  address          String?
  taxNumber        String?
  currency         String    @default("AED")
  timezone         String    @default("Asia/Dubai")
  locale           String    @default("ar")
  isActive         Boolean   @default(true)
  planId           String?   // Current plan ID
  deletedAt        DateTime? // Soft delete
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  users            User[]
  subscriptions    Subscription[]
  plan             Plan?     @relation(fields: [planId], references: [id])

  @@index([deletedAt])
}

model Plan {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  nameAr          String?   // Arabic name
  description     String?
  descriptionAr   String?   // Arabic description
  price           Float
  currency        String    @default("AED")
  interval        SubscriptionInterval @default(MONTH)
  stripeProductId String?
  stripePriceId   String?
  features        String    @default("{}")
  limits          String    @default("{}")
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())

  subscriptions   Subscription[]
  organizations   Organization[]
}

model Subscription {
  id                  String    @id @default(cuid())
  organizationId      String
  planId              String
  status              SubscriptionStatus @default(ACTIVE)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean   @default(false)
  stripeSubscriptionId String?
  stripeCustomerId    String?
  stripePaymentIntentId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan               Plan        @relation(fields: [planId], references: [id])
  payments           Payment[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([planId])
}

model Payment {
  id                  String    @id @default(cuid())
  subscriptionId      String
  amount              Float
  currency            String    @default("AED")
  status              PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeChargeId      String?
  stripeInvoiceId     String?
  receiptUrl          String?
  description         String?
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  subscription        Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

// ============================================
// المستخدمون والصلاحيات
// ============================================

model User {
  id              String    @id @default(cuid())
  organizationId  String?
  username        String    @unique
  email           String    @unique
  password        String?
  fullName        String?
  role            UserRole  @default(VIEWER)
  isActive        Boolean   @default(true)
  emailVerified   DateTime?
  avatar          String?
  language        String    @default("ar")
  theme           String    @default("dark")
  phone           String?
  jobTitle        String?
  department      String?
  lastLoginAt     DateTime?
  deletedAt       DateTime? // Soft delete
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization?  @relation(fields: [organizationId], references: [id])
  sessions        Session[]
  managedProjects Project[]      @relation("ProjectManager")
  activities      Activity[]
  assignedPhases       WorkflowPhase[]     @relation("PhaseAssignee")
  DraftAssignee  WorkflowPhase[]  @relation("DraftAssignee")
  respondedInteractions ClientInteraction[] @relation("InteractionResponder")
  municipalityCorrespondence MunicipalityCorrespondence[]

  @@index([organizationId])
  @@index([email])
  @@index([deletedAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// التحقق من البريد الإلكتروني (Email Verification)
// ============================================

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  userId    String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

// ============================================
// إعادة تعيين كلمة المرور (Password Reset)
// ============================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  userId    String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

// ============================================
// المصادقة الثنائية (Two-Factor Authentication)
// ============================================

model TwoFactorSecret {
  id           String   @id @default(cuid())
  userId       String   @unique
  secret       String   // Encrypted TOTP secret
  backupCodes  Json
  isEnabled    Boolean  @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model TwoFactorChallenge {
  id        String   @id @default(cuid())
  userId    String
  code      String
  type      TwoFactorChallengeType @default(TOTP)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
}

// ============================================
// المشاريع (Core Models)
// ============================================

model Project {
  id                  String    @id @default(cuid())
  organizationId      String?
  name                String
  projectNumber       String?   @unique
  location            String?
  projectType         String?
  status              ProjectStatus @default(PENDING)
  progressPercentage  Float     @default(0.0)
  description         String?
  contractValue       Float?
  contractDate        DateTime?
  expectedStartDate   DateTime?
  expectedEndDate     DateTime?
  actualStartDate     DateTime?
  actualEndDate       DateTime?
  plotNumber           String?        // Plot/Parcel number
  customerFileNumber    String?        // Customer file number (رقم ملف العميل)
  visitDate            DateTime?      // Initial site visit date
  paymentReceived      Float          @default(0)  // Total payments received
  remainingBalance     Float          @default(0)  // Remaining contract balance
  managerId           String?   // Project manager (User ID)
  clientId            String?   // Client reference
  budget              Float?    // Project budget
  governmentApprovalStatus GovernmentApprovalStatus @default(PENDING)
  governmentApprovalDate  DateTime?                 // Date of government approval
  licenseNumber       String?                       // License/permit number
  municipalityNotes   String?                       // Notes from municipality
  electricalStatus    UtilityConnectionStatus @default(NOT_STARTED)
  plumbingStatus      UtilityConnectionStatus @default(NOT_STARTED)
  hvacStatus          UtilityConnectionStatus @default(NOT_STARTED)
  deletedAt           DateTime? // Soft delete
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tasks               Task[]
  risks               Risk[]
  transmittals        Transmittal[]
  boqItems            BOQItem[]
  defects             Defect[]
  siteReports         SiteReport[]
  proposals           Proposal[]
  contracts           Contract[]
  budgets             Budget[]
  documents           Document[]
  activities          Activity[]
  workflowPhases      WorkflowPhase[]
  clientInteractions  ClientInteraction[]
  municipalityCorrespondence MunicipalityCorrespondence[]

  client              Client?   @relation(fields: [clientId], references: [id])
  manager             User?     @relation("ProjectManager", fields: [managerId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([deletedAt])
  @@index([organizationId, status])
  @@index([managerId])
}

// ============================================
// جدول الكميات (Bill of Quantities)
// ============================================

model BOQItem {
  id            String    @id @default(cuid())
  projectId     String
  itemNumber    String?
  description   String
  unit          String?
  quantity      Float     @default(0)
  unitPrice     Float     @default(0)
  totalPrice    Float     @default(0)
  category      BOQCategory?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  siteLogItems   SiteLogItem[]
  invoiceItems  InvoiceItem[]

  @@index([projectId])
  @@index([projectId, category])
}

// ============================================
// العيوب والملاحظات (Defects Tracking)
// ============================================

model Defect {
  id              String    @id @default(cuid())
  projectId       String
  title           String
  description     String?
  severity        DefectSeverity @default(MEDIUM)
  status          DefectStatus @default(OPEN)
  location        String?
  imageId         String?
  assignedTo      String?
  resolvedAt      DateTime?
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  siteReportId     String?
  siteReport       SiteReport? @relation(fields: [siteReportId], references: [id])

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, status])
  @@index([projectId, severity])
  @@index([siteReportId])
}

// ============================================
// Site Log Items (Site + BOQ Integration)
// ============================================

model SiteLogItem {
  id          String     @id @default(cuid())
  siteReportId String
  boqItemId   String?
  description String
  quantity    Float     @default(0)
  unitPrice   Float     @default(0)
  totalPrice  Float     @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  siteReport SiteReport @relation(fields: [siteReportId], references: [id], onDelete: Cascade)
  boqItem    BOQItem?   @relation(fields: [boqItemId], references: [id], onDelete: SetNull)

  @@index([siteReportId])
  @@index([boqItemId])
}

// ============================================
// تقارير الموقع (Site Diary)
// ============================================

model SiteReport {
  id                String    @id @default(cuid())
  projectId         String
  reportDate        DateTime  @default(now())
  reportNumber      String?
  weather           String?
  temperature       Float?
  workersCount      Int       @default(0)
  workDescription   String?
  workArea          String?
  workProgress      Float     @default(0)
  issues            String?
  safetyIssues      String?
  equipmentUsed     String?
  materialsReceived String?
  nextSteps         String?
  nextDayPlan       String?
  preparedById      String?
  approvedById      String?
  photos            Json?   // JSON array
  attachments       Json?   // JSON array
  summary           String?
  status            SiteReportStatus @default(DRAFT)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  logItems          SiteLogItem[]
  defects           Defect[]
}

// ============================================
// العروض والمقترحات (Proposals System)
// ============================================

model Proposal {
  id              String    @id @default(cuid())
  organizationId  String?
  projectId       String?
  proposalNumber  String    @unique
  clientId        String?
  title           String?
  issueDate       DateTime?
  validUntil      DateTime?
  subtotal        Float     @default(0)
  taxRate         Float     @default(5)
  taxAmount       Float     @default(0)
  discountAmount  Float     @default(0)
  totalAmount     Float     @default(0)
  status          ProposalStatus @default(DRAFT)
  notes           String?
  terms           String?
  deletedAt       DateTime? // Soft delete
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items           ProposalItem[]

  @@index([deletedAt])
}

model ProposalItem {
  id            String    @id @default(cuid())
  proposalId    String
  description   String
  quantity      Float     @default(1)
  unitPrice     Float     @default(0)
  unit          String?
  total         Float     @default(0)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  proposal      Proposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

model Task {
  id            String    @id @default(cuid())
  title         String
  titleAr       String?   // العنوان بالعربية
  description   String?
  projectId     String?
  parentId      String?   // For task hierarchy/subtasks
  assignedTo    String?   // User ID assigned to task
  priority      TaskPriority @default(MEDIUM)
  status        TaskStatus @default(TODO)
  startDate     DateTime? // For Gantt chart
  endDate       DateTime? // For Gantt chart
  dueDate       DateTime?
  progress      Float     @default(0) // 0-100
  
  // ============================================
  // NEW: Duration fields (unified in minutes)
  // وحدات الوقت موحدة (الدقائق كوحدة أساسية)
  // ============================================
  estimatedMinutes Int?    // المدة التقديرية بالدقائق
  actualMinutes    Int?    // المدة الفعلية بالدقائق
  estimatedHours   Float?  // للتوافق مع الكود القديم
  actualHours      Float?  // للتوافق مع الكود القديم
  
  // ============================================
  // NEW: SLA fields for government approvals
  // حقول SLA للاعتمادات الحكومية
  // ============================================
  taskType         TaskType @default(STANDARD)
  slaDays          Int?       // عدد أيام SLA المحددة
  slaWarningDays   Int?       // أيام التحذير قبل انتهاء SLA
  slaStartDate     DateTime?  // تاريخ بدء حساب SLA
  slaBreachedAt    DateTime?  // تاريخ تجاوز SLA
  isMandatory      Boolean @default(false) // مهمة إلزامية للمشروع
  workflowTemplate String?    // قالب سير العمل (FEWA, DEFENSE, etc.)
  governmentEntity String?    // الجهة الحكومية المختصة
  
  dependencies  Json?
  order         Int       @default(0) // Sort order for Gantt display
  color         String?   // Color code for Gantt bar
  isMilestone   Boolean   @default(false) // Milestone marker
  deletedAt     DateTime? // Soft delete
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        Task?     @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks      Task[]    @relation("TaskHierarchy")
  slaBreaches   SLABreach[]

  @@index([deletedAt])
  @@index([projectId])
  @@index([projectId, status])
  @@index([assignedTo])
  @@index([taskType])
  @@index([isMandatory])
  @@index([workflowTemplate])
}

// ============================================
// سجل المخاطر (Risk Register)
// ============================================

model Risk {
  id              String    @id @default(cuid())
  projectId       String?
  title           String
  description     String?
  category        RiskCategory @default(TECHNICAL)
  probability     Int       @default(1) // 1-5 (Low to High)
  impact          Int       @default(1) // 1-5 (Low to High)
  riskScore       Int       @default(1) // probability * impact
  status          RiskStatus @default(OPEN)
  priority        PriorityLevel @default(MEDIUM)
  identifiedDate  DateTime  @default(now())
  targetDate      DateTime? // Target resolution date
  closedDate      DateTime?
  owner           String?   // User ID responsible for risk
  mitigationPlan  String?
  contingencyPlan String?
  triggerEvents   Json?
  responseStrategy RiskResponseStrategy?
  residualRisk    Int?      // Risk score after mitigation
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  riskActions     RiskAction[]

  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model RiskAction {
  id          String    @id @default(cuid())
  riskId      String
  action      String
  assignedTo  String?   // User ID
  dueDate     DateTime?
  status      RiskActionStatus @default(PENDING)
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  risk        Risk      @relation(fields: [riskId], references: [id], onDelete: Cascade)
}

// ============================================
// نظام الإرسال (Transmittal System)
// ============================================

model Transmittal {
  id                String    @id @default(cuid())
  projectId         String?
  transmittalNumber String    @unique
  subject           String
  description       String?
  senderId          String?   // User ID
  recipientName     String
  recipientEmail    String?
  recipientCompany  String?
  recipientPhone    String?
  sendDate          DateTime  @default(now())
  dueDate           DateTime?
  status            TransmittalStatus @default(DRAFT)
  priority          PriorityLevel @default(NORMAL)
  deliveryMethod    TransmittalDeliveryMethod @default(EMAIL)
  trackingNumber    String?   // For courier/post
  acknowledgedDate  DateTime?
  acknowledgedBy    String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  items             TransmittalItem[]
  responses         TransmittalResponse[]

  project           Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TransmittalItem {
  id              String    @id @default(cuid())
  transmittalId   String
  documentNumber  String
  documentTitle   String
  revision        String    @default("A")
  copies          Int       @default(1)
  documentType    String?   // drawing, specification, report, calculation, etc.
  status          TransmittalItemStatus @default(FOR_REVIEW)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transmittal     Transmittal @relation(fields: [transmittalId], references: [id], onDelete: Cascade)
}

model TransmittalResponse {
  id              String    @id @default(cuid())
  transmittalId   String
  responseDate    DateTime  @default(now())
  responseType    TransmittalResponseType
  respondentName  String
  respondentEmail String?
  comments        String?
  attachments     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transmittal     Transmittal @relation(fields: [transmittalId], references: [id], onDelete: Cascade)

  @@index([transmittalId])
}

// ============================================
// العميل والفاتورة
// ============================================

model Client {
  id             String    @id @default(cuid())
  organizationId String?
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  country        String?
  taxNumber      String?
  contactPerson  String?
  creditLimit    Float     @default(0)
  paymentTerms   Int       @default(30) // days
  notes          String?
  isActive       Boolean   @default(true)
  deletedAt      DateTime? // Soft delete
  createdById    String?   // User who created this client
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invoices       Invoice[]
  projects       Project[]

  @@index([organizationId])
  @@index([deletedAt])
  @@index([organizationId, isActive])
  @@index([createdById])
}

model Invoice {
  id              String    @id @default(cuid())
  organizationId  String?
  invoiceNumber   String    @unique
  clientId        String?
  projectId       String?
  issueDate       DateTime?
  dueDate         DateTime?
  subtotal        Float     @default(0.0)
  taxRate         Float     @default(5.0)
  taxAmount       Float     @default(0.0)
  total           Float     @default(0.0)
  paidAmount      Float     @default(0.0)
  status          InvoiceStatus @default(DRAFT)
  notes           String?
  deletedAt       DateTime? // Soft delete
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client?   @relation(fields: [clientId], references: [id])
  items           InvoiceItem[]

  @@index([deletedAt])
  @@index([clientId])
  @@index([organizationId, status])
}

// ============================================
// بنود الفاتورة (Invoice Items)
// ============================================

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  boqItemId   String?  // Optional link to BOQ item

  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  unit        String   @default("unit")
  totalPrice  Float    @default(0)
  notes       String?

  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  boqItem     BOQItem? @relation(fields: [boqItemId], references: [id])

  @@index([invoiceId])
  @@index([boqItemId])
}

// ============================================
// الموارد البشرية (HR Management)
// ============================================

model Attendance {
  id            String    @id @default(cuid())
  userId        String
  date          DateTime  @default(now())
  checkIn       String?   // Time string HH:mm
  checkOut      String?   // Time string HH:mm
  status        AttendanceStatus @default(PRESENT)
  workHours     Float     @default(0)
  overtimeHours Float     @default(0)
  notes         String?
  location      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model LeaveRequest {
  id              String    @id @default(cuid())
  userId          String
  leaveType       LeaveType @default(ANNUAL)
  startDate       DateTime
  endDate         DateTime
  daysCount       Float     @default(1)
  reason          String?
  status          LeaveRequestStatus @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  attachment      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([leaveType])
}

// ============================================
// المخزون والمشتريات (Inventory & Purchase Orders)
// ============================================

model Material {
  id              String    @id @default(cuid())
  organizationId  String?
  materialCode    String?   @unique
  name            String
  description     String?
  category        String?
  unit            String
  unitPrice       Float     @default(0)
  currentStock    Float     @default(0)
  minStock        Float     @default(0)
  maxStock        Float     @default(0)
  reorderLevel    Float     @default(0)   // Stock level that triggers low-stock alert
  location        String?   // Warehouse location
  supplierId      String?
  leadTime        Int       @default(0)   // Days to receive order
  isActive        Boolean   @default(true)
  lastRestockedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    MaterialTransaction[]

  @@index([organizationId])
  @@index([category])
}

model MaterialTransaction {
  id              String    @id @default(cuid())
  materialId      String
  projectId       String?
  transactionType MaterialTransactionType @default(IN)
  quantity        Float     @default(0)
  unitPrice       Float?
  totalValue      Float?
  notes           String?
  reference       String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  material        Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId])
  @@index([projectId])
  @@index([createdById])
}

model PurchaseOrder {
  id                String    @id @default(cuid())
  organizationId    String?
  poNumber          String    @unique
  supplierId        String?
  projectId         String?
  orderDate         DateTime  @default(now())
  expectedDate      DateTime?
  subtotal          Float     @default(0)
  taxRate           Float     @default(5)
  taxAmount         Float     @default(0)
  totalAmount       Float     @default(0)
  status            PurchaseOrderStatus @default(DRAFT)
  notes             String?
  terms             String?
  approvedById      String?
  approvedAt        DateTime?
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  items             PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String    @id @default(cuid())
  purchaseOrderId String
  materialId      String?
  description     String
  quantity        Float     @default(1)
  unitPrice       Float     @default(0)
  unit            String?
  total           Float     @default(0)
  receivedQty     Float     @default(0)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

// ============================================
// قاعدة المعرفة (Knowledge Base)
// ============================================

model KnowledgeArticle {
  id              String    @id @default(cuid())
  organizationId  String?
  title           String
  content         String    // Markdown content
  category        KnowledgeCategory?
  tags            Json?
  authorId        String?
  isPublished     Boolean   @default(false)
  viewCount       Int       @default(0)
  helpfulCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// الإشعارات (Notifications)
// ============================================

model Notification {
  id                String    @id @default(cuid())
  userId            String
  title             String
  message           String?
  notificationType  NotificationType @default(SYSTEM)
  referenceType     String?
  referenceId       String?
  isRead            Boolean   @default(false)
  priority          PriorityLevel @default(NORMAL)
  readAt            DateTime?
  actionUrl         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([userId, isRead])
  @@index([notificationType])
}

// ============================================
// الموردون (Suppliers)
// ============================================

model Supplier {
  id              String    @id @default(cuid())
  organizationId  String?
  name            String
  supplierType    SupplierType @default(MATERIALS)
  email           String?
  phone           String?
  address         String?
  taxNumber       String?
  contactPerson   String?
  rating          Float     @default(0)
  creditLimit     Float     @default(0)
  isApproved      Boolean   @default(false)
  isActive        Boolean   @default(true)
  notes           String?
  createdById     String?   // User who created this supplier
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
  @@index([createdById])
}

// ============================================
// العقود والتوقيع الإلكتروني (Contracts & E-Signature)
// ============================================

model Contract {
  id                String    @id @default(cuid())
  organizationId    String?
  projectId         String?
  clientId          String?
  contractNumber    String    @unique
  title             String
  description       String?
  contractType      ContractType @default(SERVICE)
  status            ContractStatus @default(DRAFT)
  value             Float     @default(0)
  currency          String    @default("AED")
  startDate         DateTime?
  endDate           DateTime?
  signedDate        DateTime?
  terminationDate   DateTime?
  terms             String?   // Contract terms (markdown)
  notes             String?
  createdBy         String?   // User ID
  deletedAt         DateTime? // Soft delete
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  signatures        ContractSignature[]
  amendments        ContractAmendment[]
  documents         Document[]

  project           Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@index([clientId])
  @@index([deletedAt])
}

model ContractSignature {
  id              String    @id @default(cuid())
  contractId      String
  signatoryName   String
  signatoryEmail  String
  signatoryRole   String?   // client, contractor, witness, etc.
  signatureData   String?   // Base64 encoded signature image
  signedAt        DateTime?
  ipAddress       String?
  userAgent       String?
  status          SignatureStatus @default(PENDING)
  declinedAt      DateTime?
  declineReason   String?
  invitationSentAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([signatoryEmail])
}

model ContractAmendment {
  id              String    @id @default(cuid())
  contractId      String
  amendmentNumber String
  title           String
  description     String?
  effectiveDate   DateTime
  status          AmendmentStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

// ============================================
// إدارة المستندات (Document Management)
// ============================================

model Document {
  id              String    @id @default(cuid())
  organizationId  String?
  projectId       String?
  contractId      String?
  documentNumber  String?
  title           String
  description     String?
  documentType    DocumentType @default(GENERAL)
  category        DocumentCategory?
  fileName        String
  filePath        String
  fileSize        Int?
  mimeType        String?
  version         String    @default("1.0")
  revision        String    @default("A")
  status          DocumentStatus @default(DRAFT)
  uploadedBy      String?   // User ID
  approvedBy      String?   // User ID
  approvedAt      DateTime?
  tags            Json?   // JSON array
  metadata        Json?   // JSON for additional metadata
  deletedAt       DateTime? // Soft delete
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contract        Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([documentType])
  @@index([deletedAt])
}

// ============================================
// الموازنة (Budget Management)
// ============================================

model Budget {
  id              String    @id @default(cuid())
  projectId       String
  name            String
  budgetType      String    @default("project") // project, phase, category
  parentBudgetId  String?   // For hierarchical budgets
  plannedAmount   Float     @default(0)
  actualAmount    Float     @default(0)
  committedAmount Float     @default(0) // PO/contracts committed
  remainingAmount Float     @default(0)
  variance        Float     @default(0)
  category        String?   // labor, materials, equipment, subcontractor, overhead
  startDate       DateTime?
  endDate         DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent          Budget?   @relation("BudgetHierarchy", fields: [parentBudgetId], references: [id], onDelete: Cascade)
  children        Budget[]  @relation("BudgetHierarchy")

  @@index([projectId])
  @@index([category])
}

// ============================================
// سجل النشاطات (Activity Log / Audit Trail)
// ============================================

model Activity {
  id              String    @id @default(cuid())
  organizationId  String?
  userId          String?
  projectId       String?
  entityType      String    // project, task, invoice, contract, etc.
  entityId        String?   // ID of the affected entity
  action          String    // create, update, delete, view, approve, reject, sign
  description     String
  oldValue        Json?
  newValue        Json?
  ipAddress       String?
  userAgent       String?
  metadata        Json?   // JSON for additional context
  createdAt       DateTime  @default(now())

  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  project         Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId, entityType])
}

// ============================================
// Engineering Workflow Phase (Engineering OS)
// ============================================

model WorkflowPhase {
  id              String   @id @default(cuid())
  projectId       String
  phaseType       String   // ARCHITECTURAL_SKETCH, ARCHITECTURAL_CONCEPT, CLIENT_APPROVAL, etc.
  phaseCategory   String   // ARCHITECTURAL, STRUCTURAL, MEP, GOVERNMENT, CONTRACTING
  status          String   @default("NOT_STARTED")  // NOT_STARTED, IN_PROGRESS, COMPLETED, ON_HOLD, DELAYED, REJECTED
  startDate       DateTime?
  endDate         DateTime?
  slaDays         Int      @default(0)
  assignedToId    String?
  notes           String?
  order           Int      @default(0)
  dependsOnId     String?
  rejectionCount  Int      @default(0)
  draftAssignedToId    String?                          // Draftsman assigned to this phase
  draftStartDate       DateTime?                        // Drafting start date
  draftEndDate         DateTime?                        // Drafting end date
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo      User?           @relation("PhaseAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  draftAssignedTo  User?           @relation("DraftAssignee", fields: [draftAssignedToId], references: [id], onDelete: SetNull)
  dependsOn       WorkflowPhase?  @relation("PhaseDependency", fields: [dependsOnId], references: [id], onDelete: SetNull)
  dependentPhases WorkflowPhase[] @relation("PhaseDependency")
  interactions    ClientInteraction[]

  @@index([projectId])
  @@index([projectId, phaseCategory])
  @@index([status])
  @@index([assignedToId])
}

// ============================================
// Client Interaction (Engineering OS)
// ============================================

model ClientInteraction {
  id              String   @id @default(cuid())
  projectId       String
  phaseId         String?
  interactionType String   @default("COMMENT")  // APPROVE, REJECT, COMMENT
  content         String
  respondedById   String?
  responseContent String?
  responseDate    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase           WorkflowPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  respondedBy     User?           @relation("InteractionResponder", fields: [respondedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([phaseId])
  @@index([interactionType])
}

// ============================================
// NEW: Project Templates for Government Approvals
// قوالب المشاريع للاعتمادات الحكومية
// ============================================

/// Project template for predefined workflows
model ProjectTemplate {
  id              String    @id @default(cuid())
  name            String                      // "FEWA", "Civil Defense", "Municipality"
  nameAr          String?                     // "هيئة كهرباء"، "دفاع مدني"
  code            String    @unique           // Short code: "FEWA", "DEFENSE", "MUNICIPALITY"
  description     String?
  descriptionAr   String?
  category        String?                     // "utility", "safety", "municipality", "communications"
  isActive        Boolean   @default(true)
  estimatedDays   Int       @default(0)       // Total estimated days
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tasks           ProjectTemplateTask[]

  @@index([isActive])
  @@index([category])
}

/// Template task for project templates
model ProjectTemplateTask {
  id                String    @id @default(cuid())
  templateId        String
  taskName          String                      // Task name
  taskNameAr        String?                     // اسم المهمة
  description       String?
  descriptionAr     String?
  taskType          TaskType @default(GOVERNMENTAL)
  slaDays           Int       @default(7)       // SLA in days
  slaWarningDays    Int       @default(1)       // Warning days before SLA breach
  estimatedMinutes  Int?                        // Duration in minutes
  order             Int       @default(0)       // Execution order
  dependencies      Json?                       // Array of previous task orders
  governmentEntity  String?                     // Government entity name
  governmentEntityAr String?                    // اسم الجهة الحكومية
  isMandatory       Boolean   @default(true)
  color             String?                     // Color for Gantt chart
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  template          ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([order])
}

// ============================================
// NEW: SLA Breach Tracking
// تتبع تجاوزات SLA
// ============================================

/// SLA breach record for monitoring
model SLABreach {
  id              String    @id @default(cuid())
  taskId          String
  projectId       String?
  status          SLABreachStatus @default(WARNING)
  daysElapsed     Int       @default(0)       // Days since SLA start
  slaDays         Int       @default(0)       // Expected SLA days
  breachDays      Int       @default(0)       // Days over SLA (negative if not yet breached)
  notifiedAt      DateTime?                   // When notification was sent
  notifiedUsers   Json?                       // Array of user IDs notified
  resolvedAt      DateTime?                   // When breach was resolved
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// NEW: Cron Job Execution Log
// سجل تنفيذ المهام المجدولة
// ============================================

/// Cron job execution log for monitoring
model CronJobLog {
  id              String    @id @default(cuid())
  jobName         String                      // "sla-monitor", "backup", etc.
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  status          String    @default("running") // running, completed, failed
  recordsProcessed Int      @default(0)
  breachesFound   Int       @default(0)
  notificationsSent Int     @default(0)
  error           String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  @@index([jobName])
  @@index([startedAt])
  @@index([status])
}

// ============================================
// المراسلات البلدية (Municipality Correspondence)
// تتبع التفاعلات مع البلديات على مدار الوقت
// ============================================

model MunicipalityCorrespondence {
  id              String   @id @default(cuid())
  projectId       String
  correspondenceType String  // SUBMISSION, RESPONSE, REJECTION, APPROVAL, INQUIRY, AMENDMENT
  
  referenceNumber String?  // الرقم المرجعي الرسمي من البلدية
  submissionDate  DateTime @default(now())
  responseDate    DateTime?
  
  subject         String?  // موضوع مختصر / Brief subject line
  content         String?  // المحتوى الكامل للمراسلة / Full content/text
  notes           String?  // ملاحظات داخلية من الاستشاري / Internal notes
  
  status          String   @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, REJECTED, AMENDMENT_REQUIRED
  
  attachments     Json?    // قائمة المرفقات / List of attached documents
  responseNotes   String?  // رد البلدية / Municipality response notes
  
  createdById     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation(fields: [createdById], references: [id])
  
  @@index([projectId])
  @@index([status])
  @@index([correspondenceType])
}

// BluePrint Engineering Consultancy - Enterprise SaaS Platform
// نظام إدارة مكاتب الاستشارات الهندسية - منصة SaaS متكاملة

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// المنظمة والاشتراكات (SaaS Core)
// ============================================

model Organization {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  logo           String?
  description    String?
  website        String?
  phone          String?
  email          String?
  address        String?
  taxNumber      String?
  currency       String    @default("AED")
  timezone       String    @default("Asia/Dubai")
  locale         String    @default("ar")
  isActive       Boolean   @default(true)
  planId         String?
  trialEndsAt    DateTime?
  subscriptionStatus String @default("trial")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  users          User[]
  projects       Project[]
  clients        Client[]
  suppliers      Supplier[]
  invoices       Invoice[]
  proposals      Proposal[]
  contracts      Contract[]
  materials      Material[]
  settings       OrganizationSetting[]
  subscriptions  Subscription[]
  integrations   Integration[]
}

model Subscription {
  id              String    @id @default(cuid())
  organizationId  String
  planId          String
  status          String    @default("active")
  currentPeriodStart DateTime
  currentPeriodEnd DateTime
  cancelAtPeriodEnd Boolean @default(false)
  stripeSubscriptionId String?
  stripeCustomerId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           Plan @relation(fields: [planId], references: [id])
}

model Plan {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String?
  price           Float
  currency        String    @default("AED")
  interval        String    @default("month")
  features        String    // JSON string
  limits          String    // JSON string for limits
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())

  subscriptions   Subscription[]
}

model OrganizationSetting {
  id              String    @id @default(cuid())
  organizationId  String
  key             String
  value           String?
  category        String    @default("general")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([organizationId, key])
}

model Integration {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  type            String
  config          String?   // JSON
  isActive        Boolean   @default(true)
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================
// المستخدمون والصلاحيات
// ============================================

model User {
  id              String   @id @default(cuid())
  organizationId  String?
  username        String   @unique
  email           String   @unique
  password        String
  fullName        String?
  role            String   @default("viewer")
  isActive        Boolean  @default(true)
  emailVerified   DateTime?
  avatar          String?
  language        String   @default("ar")
  theme           String   @default("dark")
  phone           String?
  jobTitle        String?
  department      String?
  hireDate        DateTime?
  salary          Float?
  leaveBalance    Float    @default(30.0)
  nationality     String?
  timezone        String   @default("Asia/Dubai")
  lastLoginAt     DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  preferences     String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id])
  projects        ProjectUser[]
  attendances     Attendance[]
  leaveRequests   LeaveRequest[]  @relation("UserLeaveRequests")
  approvedLeaves  LeaveRequest[]  @relation("UserApprovedLeaves")
  notifications   Notification[]
  createdTasks    Task[]          @relation("TaskCreator")
  assignedTasks   Task[]          @relation("TaskAssignee")
  uploadedDocs    Document[]
  auditLogs       AuditLog[]
  apiKeys         ApiKey[]
  sessions        Session[]
  comments        Comment[]
  activities      Activity[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id            String   @id @default(cuid())
  userId        String
  name          String
  key           String   @unique
  permissions   String?  // JSON
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProjectUser {
  id          String  @id @default(cuid())
  projectId   String
  userId      String
  permission  String  @default("read")

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([projectId, userId])
}

// ============================================
// العملاء والمشاريع
// ============================================

model Client {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  taxNumber      String?
  contactPerson  String?
  website        String?
  notes          String?
  isActive       Boolean   @default(true)
  clientType     String    @default("company")
  creditLimit    Float     @default(0)
  totalInvoiced  Float     @default(0)
  totalPaid      Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects       Project[]
  invoices       Invoice[]
  proposals      Proposal[]
  contracts      Contract[]
}

model Project {
  id                  String    @id @default(cuid())
  organizationId      String
  name                String
  projectNumber       String?   @unique
  location            String?
  projectType         String?
  clientId            String?
  contractValue       Float?
  contractDate        DateTime?
  expectedStartDate   DateTime?
  expectedEndDate     DateTime?
  actualStartDate     DateTime?
  actualEndDate       DateTime?
  projectManagerId    String?
  status              String    @default("pending")
  progressPercentage  Float     @default(0.0)
  description         String?
  notes               String?
  tags                String?   // JSON array
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client              Client?              @relation(fields: [clientId], references: [id])
  users               ProjectUser[]
  analyses            Analysis[]
  siteReports         SiteReport[]
  boqItems            BOQItem[]
  files               UploadedFile[]
  defects             Defect[]
  tasks               Task[]
  invoices            Invoice[]
  budgets             Budget[]
  expenses            Expense[]
  correspondences     Correspondence[]
  memoryEntries       MemoryEntry[]
  workflows           Workflow[]
  proposals           Proposal[]
  siteVisits          SiteVisit[]
  milestones          ProjectMilestone[]
  comments            Comment[]
  activities          Activity[]
}

model ProjectMilestone {
  id            String    @id @default(cuid())
  projectId     String
  name          String
  description   String?
  plannedDate   DateTime?
  actualDate    DateTime?
  status        String    @default("pending")
  progress      Float     @default(0)
  createdAt     DateTime  @default(now())

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================
// التحليلات والتصميم
// ============================================

model Analysis {
  id            String    @id @default(cuid())
  projectId     String
  taskType      String?
  inputText     String?
  resultJson    String?
  safetyStatus  String    @default("Pending")
  notes         String?
  createdAt     DateTime  @default(now())

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SiteReport {
  id              String    @id @default(cuid())
  projectId       String
  reportDate      DateTime  @default(now())
  reportNumber    String?
  weather         String?
  temperature     Float?
  workersCount    Int?
  workDescription String?
  workArea        String?
  workProgress    Float     @default(0)
  issues          String?
  safetyIssues    String?
  equipmentUsed   String?
  materialsReceived String?
  nextSteps       String?
  nextDayPlan     String?
  preparedById    String?
  approvedById    String?
  photos          String?   // JSON array
  attachments     String?   // JSON array
  summary         String?
  status          String    @default("draft")
  createdAt       DateTime  @default(now())

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SiteVisit {
  id              String    @id @default(cuid())
  projectId       String
  visitDate       DateTime
  visitType       String    @default("inspection")
  visitors        String?
  purpose         String?
  findings        String?
  recommendations String?
  photos          String?   // JSON array
  createdById     String?
  createdAt       DateTime  @default(now())

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BOQItem {
  id            String    @id @default(cuid())
  projectId     String
  itemNumber    String?
  description   String
  unit          String?
  quantity      Float?
  unitPrice     Float?
  totalPrice    Float?
  category      String?
  notes         String?
  createdAt     DateTime  @default(now())

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model UploadedFile {
  id            String    @id @default(cuid())
  projectId     String
  filename      String
  originalName  String?
  fileType      String?
  filePath      String
  fileSize      Int?
  mimeType      String?
  analyzed      Boolean   @default(false)
  analysisResult String?
  uploadedById  String?
  tags          String?   // JSON
  createdAt     DateTime  @default(now())

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Defect {
  id              String    @id @default(cuid())
  projectId       String
  title           String?
  description     String?
  severity        String    @default("medium")
  status          String    @default("Open")
  location        String?
  imageId         String?
  assignedTo      String?
  resolvedAt      DateTime?
  resolutionNotes String?
  createdAt       DateTime  @default(now())

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================
// المالية والفواتير
// ============================================

model Invoice {
  id              String    @id @default(cuid())
  organizationId  String?
  invoiceNumber   String    @unique
  projectId       String?
  clientId        String?
  issueDate       DateTime?
  dueDate         DateTime?
  items           String?   // JSON
  subtotal        Float     @default(0.0)
  taxRate         Float     @default(5.0)
  taxAmount       Float     @default(0.0)
  discountAmount  Float     @default(0.0)
  total           Float     @default(0.0)
  paidAmount      Float     @default(0.0)
  status          String    @default("draft")
  notes           String?
  terms           String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id])
  project         Project?  @relation(fields: [projectId], references: [id])
  client          Client?   @relation(fields: [clientId], references: [id])
  payments        Payment[]
}

model Payment {
  id              String    @id @default(cuid())
  invoiceId       String
  amount          Float
  paymentDate     DateTime
  paymentMethod   String
  referenceNumber String?
  notes           String?
  createdAt       DateTime  @default(now())

  invoice         Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Proposal {
  id              String    @id @default(cuid())
  organizationId  String?
  proposalNumber  String
  projectId       String?
  clientId        String?
  title           String?
  issueDate       DateTime?
  validUntil      DateTime?
  items           String?   // JSON
  subtotal        Float     @default(0.0)
  taxRate         Float     @default(5.0)
  taxAmount       Float     @default(0.0)
  discountAmount  Float     @default(0.0)
  totalAmount     Float     @default(0.0)
  status          String    @default("draft")
  notes           String?
  terms           String?
  createdAt       DateTime  @default(now())

  organization    Organization? @relation(fields: [organizationId], references: [id])
  project         Project?  @relation(fields: [projectId], references: [id])
  client          Client?   @relation(fields: [clientId], references: [id])
}

model Budget {
  id            String    @id @default(cuid())
  projectId     String
  category      String
  description   String?
  budgetAmount  Float     @default(0.0)
  actualAmount  Float     @default(0.0)
  variance      Float     @default(0.0)
  createdAt     DateTime  @default(now())

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String    @id @default(cuid())
  projectId     String?
  category      String
  description   String?
  amount        Float
  expenseDate   DateTime
  paidTo        String?
  receiptNumber String?
  receiptImage  String?
  notes         String?
  createdById   String?
  status        String    @default("pending")
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())

  project       Project?  @relation(fields: [projectId], references: [id])
}

// ============================================
// الموردين والمشتريات
// ============================================

model Supplier {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  supplierType    String    @default("supplier")
  email           String?
  phone           String?
  address         String?
  taxNumber       String?
  contactPerson   String?
  rating          Float     @default(0.0)
  creditLimit     Float     @default(0)
  isApproved      Boolean   @default(false)
  isActive        Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrders  PurchaseOrder[]
}

model Material {
  id              String    @id @default(cuid())
  organizationId  String
  materialCode    String?   @unique
  name            String
  category        String?
  unit            String
  unitPrice       Float     @default(0)
  currentStock    Float     @default(0)
  minStock        Float     @default(0)
  maxStock        Float     @default(0)
  location        String?
  supplier        String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions    MaterialTransaction[]
}

model MaterialTransaction {
  id                String    @id @default(cuid())
  materialId        String
  projectId         String?
  transactionType   String    // in, out, adjustment
  quantity          Float
  unitPrice         Float?
  totalValue        Float?
  notes             String?
  reference         String?
  createdById       String?
  createdAt         DateTime  @default(now())

  material          Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id            String    @id @default(cuid())
  poNumber      String    @unique
  supplierId    String?
  projectId     String?
  orderDate     DateTime
  expectedDate  DateTime?
  items         String?   // JSON
  subtotal      Float     @default(0)
  taxAmount     Float     @default(0)
  total         Float     @default(0)
  status        String    @default("pending")
  notes         String?
  createdById   String?
  createdAt     DateTime  @default(now())

  supplier      Supplier? @relation(fields: [supplierId], references: [id])
}

// ============================================
// العقود
// ============================================

model Contract {
  id                  String    @id @default(cuid())
  organizationId      String?
  contractNumber      String    @unique
  title               String
  projectId           String?
  clientId            String?
  supplierId          String?
  contractType        String    @default("lump_sum")
  contractValue       Float?
  startDate           DateTime?
  endDate             DateTime?
  retentionPercentage Float     @default(5.0)
  advancePayment      Float     @default(0)
  status              String    @default("draft")
  notes               String?
  terms               String?
  attachments         String?   // JSON
  createdAt           DateTime  @default(now())

  organization        Organization? @relation(fields: [organizationId], references: [id])
  client              Client?   @relation(fields: [clientId], references: [id])
  variations          ContractVariation[]
}

model ContractVariation {
  id              String    @id @default(cuid())
  contractId      String
  variationNumber String
  description     String?
  value           Float     @default(0)
  status          String    @default("pending")
  approvedDate    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())

  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

// ============================================
// الموارد البشرية
// ============================================

model Attendance {
  id            String    @id @default(cuid())
  userId        String
  date          DateTime
  checkIn       String?
  checkOut      String?
  status        String    @default("present")
  workHours     Float     @default(0)
  overtimeHours Float     @default(0)
  notes         String?
  location       String?
  ipAddress      String?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}

model LeaveRequest {
  id              String    @id @default(cuid())
  userId          String
  leaveType       String
  startDate       DateTime
  endDate         DateTime
  daysCount       Int       @default(0)
  reason          String?
  status          String    @default("pending")
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  attachment      String?
  createdAt       DateTime  @default(now())

  user            User      @relation("UserLeaveRequests", fields: [userId], references: [id], onDelete: Cascade)
  approver        User?     @relation("UserApprovedLeaves", fields: [approvedById], references: [id])
}

model SalaryPayment {
  id          String    @id @default(cuid())
  userId      String
  salaryMonth DateTime
  basicSalary Float     @default(0)
  allowances  Float     @default(0)
  overtime    Float     @default(0)
  deductions  Float     @default(0)
  netSalary   Float     @default(0)
  status      String    @default("pending")
  paidAt      DateTime?
  paymentMethod String?
  reference    String?
  notes       String?
  createdAt   DateTime  @default(now())
}

// ============================================
// المهام وسير العمل
// ============================================

model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  projectId     String?
  assignedToId  String?
  createdById   String?
  priority      String    @default("medium")
  status        String    @default("todo")
  dueDate       DateTime?
  progress      Float     @default(0)
  completedAt   DateTime?
  estimatedHours Float?
  actualHours   Float?
  tags          String?   // JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project?  @relation(fields: [projectId], references: [id])
  assignee      User?     @relation("TaskAssignee", fields: [assignedToId], references: [id])
  creator       User?     @relation("TaskCreator", fields: [createdById], references: [id])
  subtasks      SubTask[]
  comments      Comment[]
}

model SubTask {
  id          String    @id @default(cuid())
  taskId      String
  title       String
  completed   Boolean   @default(false)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Workflow {
  id            String    @id @default(cuid())
  projectId     String?
  name          String?
  description   String?
  triggerEvent  String?
  actionType    String?
  actionParams  String?
  isActive      Boolean   @default(true)
  lastRunAt     DateTime?
  createdAt     DateTime  @default(now())

  project       Project?  @relation(fields: [projectId], references: [id])
  executions    WorkflowExecution[]
}

model WorkflowExecution {
  id            String    @id @default(cuid())
  workflowId    String
  status        String    @default("pending")
  input         String?   // JSON
  output        String?   // JSON
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  workflow      Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

// ============================================
// الإشعارات والموافقات
// ============================================

model Notification {
  id                String    @id @default(cuid())
  userId            String
  title             String
  message           String?
  notificationType  String    @default("system")
  referenceType     String?
  referenceId       String?
  isRead            Boolean   @default(false)
  priority          String    @default("normal")
  readAt            DateTime?
  actionUrl         String?
  createdAt         DateTime  @default(now())

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Approval {
  id              String    @id @default(cuid())
  approvalType    String
  title           String
  description     String?
  referenceId     String?
  requestedById   String?
  status          String    @default("pending")
  approvedById    String?
  approvedAt      DateTime?
  rejectedById    String?
  rejectedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime  @default(now())
}

// ============================================
// المستندات والمراسلات
// ============================================

model Document {
  id            String    @id @default(cuid())
  filename      String
  originalName  String?
  filePath      String
  fileType      String?
  mimeType      String?
  fileSize      Int?
  category      String    @default("general")
  relatedTo     String?
  relatedId     String?
  description   String?
  tags          String?   // JSON
  version       Int       @default(1)
  uploadedById  String?
  createdAt     DateTime  @default(now())

  uploader      User?     @relation(fields: [uploadedById], references: [id])
}

model Correspondence {
  id              String    @id @default(cuid())
  projectId       String?
  referenceNumber String?
  date            DateTime  @default(now())
  direction       String    // incoming, outgoing
  type            String    @default("letter")
  subject         String
  fromParty       String?
  toParty         String?
  content         String?
  attachments     String?   // JSON
  priority        String    @default("normal")
  status          String    @default("pending")
  createdAt       DateTime  @default(now())

  project         Project?  @relation(fields: [projectId], references: [id])
}

model Comment {
  id            String    @id @default(cuid())
  content       String
  entityType    String    // project, task, document, etc.
  entityId      String
  userId        String
  parentId      String?
  mentions      String?   // JSON array of user ids
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  project       Project?  @relation(fields: [entityId], references: [id])
  task          Task?     @relation(fields: [entityId], references: [id])
}

// ============================================
// الذاكرة والسجلات
// ============================================

model MemoryEntry {
  id          String    @id @default(cuid())
  projectId   String?
  entryType   String?
  title       String?
  content     String?
  tags        String?   // JSON
  importance  Int       @default(1)
  createdAt   DateTime  @default(now())

  project     Project?  @relation(fields: [projectId], references: [id])
}

model ChatHistory {
  id          String    @id @default(cuid())
  projectId   String?
  userId      String?
  role        String
  message     String
  modelUsed   String?
  tokensUsed  Int       @default(0)
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id          String    @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  oldValues   String?   // JSON
  newValues   String?   // JSON
  notes       String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  user        User?     @relation(fields: [userId], references: [id])
}

model Activity {
  id          String    @id @default(cuid())
  userId      String?
  projectId   String?
  type        String
  title       String
  description String?
  metadata    String?   // JSON
  createdAt   DateTime  @default(now())

  user        User?     @relation(fields: [userId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
}

model Setting {
  id          String    @id @default(cuid())
  key         String    @unique
  value       String?
  category    String    @default("general")
  description String?
  isPublic    Boolean   @default(false)
  updatedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ModelTest {
  id            String    @id @default(cuid())
  projectId     String?
  testType      String
  modelName     String
  inputData     String?
  outputData    String?
  prompt        String?
  response      String?
  tokensUsed    Int       @default(0)
  responseTime  Float     @default(0)
  rating        Int?
  notes         String?
  createdById   String?
  createdAt     DateTime  @default(now())
}

// ============================================
// Templates & Automation
// ============================================

model Template {
  id          String    @id @default(cuid())
  name        String
  type        String    // invoice, proposal, report, contract, email
  content     String    // JSON or HTML
  variables   String?   // JSON
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model AutomationRule {
  id            String    @id @default(cuid())
  name          String
  trigger       String    // event type
  conditions    String?   // JSON
  actions       String    // JSON
  isActive      Boolean   @default(true)
  executionCount Int      @default(0)
  lastRunAt     DateTime?
  createdAt     DateTime  @default(now())
}

// ============================================
// Knowledge Base
// ============================================

model KnowledgeArticle {
  id          String    @id @default(cuid())
  title       String
  content     String
  category    String?
  tags        String?   // JSON
  authorId    String?
  viewCount   Int       @default(0)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================
// Vouchers - سندات القبض والصرف
// ============================================

model Voucher {
  id              String    @id @default(cuid())
  voucherNumber   String    @unique
  voucherType     String    // receipt, payment
  amount          Float
  currency        String    @default("AED")
  exchangeRate    Float     @default(1.0)
  baseAmount      Float     @default(0) // amount in base currency
  date            DateTime  @default(now())
  projectId       String?
  invoiceId       String?
  clientId        String?
  supplierId      String?
  accountId       String?   // cash/bank account
  paymentMethod   String    @default("cash")
  referenceNumber String?
  checkNumber     String?
  checkDate       DateTime?
  bankName        String?
  description     String?
  notes           String?
  status          String    @default("pending")
  approvedById    String?
  approvedAt      DateTime?
  createdById     String?
  organizationId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// Certificates - شهادات الإنجاز
// ============================================

model Certificate {
  id                String    @id @default(cuid())
  certificateNumber String    @unique
  projectId         String
  clientId          String?
  certificateType   String    @default("completion") // completion, partial, interim
  title             String
  description       String?
  percentage        Float     @default(100)
  amount            Float?
  issueDate         DateTime  @default(now())
  validUntil        DateTime?
  status            String    @default("draft")
  signedById        String?
  signedAt          DateTime?
  notes             String?
  organizationId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

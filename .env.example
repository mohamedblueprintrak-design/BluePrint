# ============================================
# BluePrint SaaS - Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# ============================================
# REQUIRED - Application
# ============================================
# The public URL of your application
NEXT_PUBLIC_APP_URL=https://your-domain.com

# JWT Secret - MUST be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# ============================================
# REQUIRED - Database
# ============================================
# PostgreSQL password (used by docker-compose.prod.yml)
# Generate with: openssl rand -base64 24
DATABASE_PASSWORD=your-secure-database-password

# ============================================
# REQUIRED - Redis
# ============================================
# Redis password (used by docker-compose.prod.yml)
# Generate with: openssl rand -base64 24
REDIS_PASSWORD=your-secure-redis-password

# ============================================
# OPTIONAL - Email Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# OPTIONAL - Stripe Payment
# ============================================
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============================================
# OPTIONAL - Rate Limiting (defaults shown)
# ============================================
# Auth endpoints - attempts per minute
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=60000

# API endpoints - requests per minute
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=60000

# Public endpoints - requests per minute
RATE_LIMIT_PUBLIC_MAX=200
RATE_LIMIT_PUBLIC_WINDOW_MS=60000

# ============================================
# OPTIONAL - CORS (comma-separated origins)
# ============================================
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ============================================
# Development Only (DO NOT use in production)
# ============================================
# DATABASE_URL is auto-generated in docker-compose.prod.yml
# Only set this for local development without Docker
# DATABASE_URL=postgresql://blueprint:password@localhost:5432/blueprint

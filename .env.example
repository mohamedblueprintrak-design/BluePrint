# ============================================
# BluePrint SaaS Platform - Environment Variables
# ============================================

# Database - PostgreSQL (Required for Vercel)
# Get free database from:
# - Vercel Postgres: https://vercel.com/dashboard -> Storage -> Create Database
# - Supabase: https://supabase.com (Free 500MB)
# - Neon: https://neon.tech (Free 3GB)

DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"
DIRECT_DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# If using Vercel Postgres, these are auto-added:
# POSTGRES_URL="postgres://..."
# POSTGRES_PRISMA_URL="postgres://..."
# POSTGRES_URL_NON_POOLING="postgres://..."

# JWT Secret (Required - Use a long random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# NextAuth Secret (for additional auth features)
NEXTAUTH_SECRET=your-nextauth-secret-change-this

# App URL (for production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

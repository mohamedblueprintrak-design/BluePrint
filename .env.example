# ============================================
# BluePrint SaaS - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
#
# Security Notes:
# - JWT_SECRET must be at least 32 characters
# - Use strong, unique passwords for DATABASE_PASSWORD and REDIS_PASSWORD
# - In production, all secrets should be set (no defaults)

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BluePrint SaaS

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection (auto-constructed in docker-compose)
DATABASE_PASSWORD=your_secure_database_password_here
# Direct URL for Prisma migrations (optional)
DIRECT_DATABASE_URL=postgresql://blueprint:your_secure_database_password_here@localhost:5432/blueprint

# ============================================
# Authentication (REQUIRED - Min 32 characters!)
# ============================================
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_change_this

# ============================================
# Redis Cache
# ============================================
REDIS_PASSWORD=your_secure_redis_password_here

# ============================================
# Email Configuration (Optional - for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# Stripe Configuration (Optional - for payments)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ============================================
# GitHub OAuth (Optional)
# ============================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ============================================
# AI Features (Optional)
# ============================================
OPENAI_API_KEY=sk-your_openai_api_key

# ============================================
# Monitoring (Optional)
# ============================================
SENTRY_DSN=https://your_sentry_dsn

# ============================================
# Rate Limiting (Optional - defaults shown)
# ============================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=60000

# ============================================
# CORS Configuration (Production)
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# Encryption Key for Sensitive Data (REQUIRED in production)
# ============================================
# Used for encrypting:
# - API keys (Stripe, OpenAI, etc.)
# - 2FA secrets
# - Personal identifiable information (PII)
# - Any data that needs to be stored securely
#
# SECURITY REQUIREMENTS:
# - MUST be exactly 64 hex characters (32 bytes)
# - MUST be unique per environment (dev/staging/prod)
# - NEVER commit a production key to version control
# - Rotate keys periodically and re-encrypt sensitive data
#
# Generate a secure key with: openssl rand -hex 32
# Or run: ./scripts/generate-keys.sh > .env.production
#
ENCRYPTION_KEY=your_64_character_hex_encryption_key_for_sensitive_data

# ============================================
# Production Security Notes
# ============================================
# For production deployment:
# 1. Run ./scripts/generate-keys.sh to generate secure keys
# 2. Set CORS_ORIGINS to your allowed domains
# 3. Use environment secrets in your CI/CD pipeline
# 4. Never log or expose these values
# 5. Rotate keys annually or after any security incident

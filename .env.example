# ===========================================
# BluePrint SaaS - Environment Configuration
# ===========================================
# نسخ هذا الملف إلى .env وتعبئة القيم المطلوبة
# Required variables are marked with [REQUIRED]
# ===========================================

# ===========================================
# Node Environment
# ===========================================
NODE_ENV=development

# ===========================================
# Database - PostgreSQL [REQUIRED]
# ===========================================
DATABASE_URL="postgresql://blueprint:changeme@localhost:5432/blueprint?schema=public"
DIRECT_DATABASE_URL="postgresql://blueprint:changeme@localhost:5432/blueprint?schema=public"

# Docker database credentials
POSTGRES_USER=blueprint
POSTGRES_PASSWORD=changeme_secure_password_here
POSTGRES_DB=blueprint
POSTGRES_PORT=5432

# ===========================================
# Authentication - JWT [REQUIRED]
# ===========================================
# MUST be at least 32 characters long
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# NextAuth (for social login)
NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-characters
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# GitHub OAuth - Social Login
# ===========================================
# Create OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===========================================
# Google OAuth - Social Login
# ===========================================
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# Stripe - Payments
# ===========================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ===========================================
# Email - SMTP
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@blueprint.saas

# ===========================================
# Redis Cache
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_PORT=6379

# ===========================================
# AI Features - OpenAI
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key

# ===========================================
# App Configuration
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="BluePrint SaaS"
NEXT_PUBLIC_APP_DESCRIPTION="نظام إدارة مكاتب الاستشارات الهندسية"

# ===========================================
# Security
# ===========================================
# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10

# API Keys for service-to-service communication (comma-separated)
API_KEYS=

# ===========================================
# Sentry - Error Tracking
# ===========================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ===========================================
# Monitoring & Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# File Upload
# ===========================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# ===========================================
# Feature Flags
# ===========================================
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_AI_FEATURES=false
ENABLE_EMAIL_VERIFICATION=false

# ===========================================
# Docker Ports (for development)
# ===========================================
HTTP_PORT=80
HTTPS_PORT=443

# ===========================================
# Vercel Deployment (for CI/CD)
# ===========================================
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Environment Variables Template
# نسخ هذا الملف إلى .env وتعبئة القيم

# ===========================================
# Database - قاعدة البيانات
# ===========================================
DATABASE_URL="postgresql://user:password@localhost:5432/blueprint?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/blueprint?schema=public"

# ===========================================
# Authentication - المصادقة
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"
JWT_EXPIRES_IN="7d"
NEXTAUTH_SECRET="your-nextauth-secret-at-least-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# GitHub OAuth - مصادقة GitHub (اختياري)
# ===========================================
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ===========================================
# Stripe - المدفوعات (اختياري)
# ===========================================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-publishable-key"

# ===========================================
# Email - البريد الإلكتروني (اختياري)
# ===========================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@blueprint.saas"

# ===========================================
# Redis Cache - التخزين المؤقت (اختياري)
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# AI Features - الذكاء الاصطناعي (اختياري)
# ===========================================
OPENAI_API_KEY="sk-your-openai-api-key"

# ===========================================
# App Configuration - إعدادات التطبيق
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BluePrint SaaS"

# ===========================================
# Sentry - تتبع الأخطاء (اختياري)
# ===========================================
SENTRY_DSN="https://your-sentry-dsn"

# ===========================================
# Rate Limiting - تحديد معدل الطلبات
# ===========================================
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"

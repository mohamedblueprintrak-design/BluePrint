# ============================================
# BluePrint SaaS Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Application
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="BluePrint SaaS"
NEXT_PUBLIC_APP_DESCRIPTION="Construction Project Management Platform"

# ============================================
# Database
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/blueprint_dev?schema=public"

# For production, use a connection pooler like Supabase or Neon
# DATABASE_URL="postgresql://user:password@host:5432/database?pgbouncer=true&connect_timeout=15"

# ============================================
# Authentication
# ============================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="2h"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Session configuration
SESSION_SECRET="your-session-secret-change-in-production"
SESSION_MAX_AGE=604800  # 7 days in seconds

# ============================================
# Email Configuration (Nodemailer)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@blueprint.dev"

# ============================================
# Stripe Configuration
# ============================================
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# ============================================
# File Storage
# ============================================
# Local storage path
UPLOAD_DIR="./uploads"

# AWS S3 (optional - for production)
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="blueprint-uploads"

# ============================================
# Redis Cache (optional)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# Logging
# ============================================
LOG_LEVEL="debug"
LOG_FORMAT="combined"

# ============================================
# Feature Flags
# ============================================
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true
ENABLE_TWO_FACTOR=false
ENABLE_API_KEY_AUTH=false

# ============================================
# Monitoring (optional)
# ============================================
# SENTRY_DSN="https://your-sentry-dsn"
# DATADOG_API_KEY="your-datadog-api-key"

# ============================================
# Demo Mode
# ============================================
DEMO_MODE=false
DEMO_USER_EMAIL="demo@blueprint.dev"
DEMO_USER_PASSWORD="Demo@123456"

# ===========================================
# BluePrint SaaS Platform - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# ===========================================

# ===========================================
# REQUIRED - Application will not start without these
# ===========================================

# Database Connection (PostgreSQL with Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/blueprint?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/blueprint?schema=public"

# JWT Secret (MUST be at least 32 characters in production!)
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"

# ===========================================
# OPTIONAL - Features will be limited without these
# ===========================================

# Application URL (for OAuth callbacks and links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo Mode (set to 'true' to enable demo users without database)
DEMO_MODE="true"

# ===========================================
# GitHub OAuth (Optional - for social login)
# ===========================================
# Create OAuth App at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/github/callback

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ===========================================
# Email Configuration (Optional - for notifications)
# ===========================================

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@blueprint.ae"

# ===========================================
# Sentry Monitoring (Optional - for error tracking)
# ===========================================

SENTRY_DSN=""

# ===========================================
# AI Features (Optional - for AI assistant)
# ===========================================

OPENAI_API_KEY=""

# ===========================================
# Development Only - DO NOT use in production
# ===========================================

NODE_ENV="development"
